<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Replace the URL below with your Azure DevOps Artifacts feed URL.
         Format: https://pkgs.dev.azure.com/{organization}/{project}/_packaging/{feed}/nuget/v3/index.json -->
    <add key="AzureArtifacts" value="https://pkgs.dev.azure.com/{organization}/{project}/_packaging/{feed}/nuget/v3/index.json" />
  </packageSources>
  <packageSourceCredentials>
    <!-- When running locally, authenticate with a PAT.
         In Azure Pipelines, use the NuGetAuthenticate task instead (see README). -->
    <AzureArtifacts>
      <add key="Username" value="az-400-demo" />
      <add key="ClearTextPassword" value="%AZURE_ARTIFACTS_PAT%" />
    </AzureArtifacts>
  </packageSourceCredentials>
</configuration>

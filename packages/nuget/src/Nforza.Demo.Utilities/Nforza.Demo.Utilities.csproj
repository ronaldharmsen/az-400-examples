<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- NuGet package metadata -->
    <PackageId>Nforza.Demo.Utilities</PackageId>
    <Version>1.0.0</Version>
    <Authors>Nforza</Authors>
    <Description>Demo utility library for AZ-400 NuGet packaging example.</Description>
    <PackageTags>demo;az-400;utilities</PackageTags>

    <!-- Generate a NuGet package on build (optional, can also use dotnet pack) -->
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
  </PropertyGroup>

</Project>
